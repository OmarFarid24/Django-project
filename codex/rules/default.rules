prefix_rule(
    pattern = ["python", "manage.py"],
    decision = "allow",
    justification = "Comandos habituales de Django.",
)

prefix_rule(
    pattern = ["git", "push"],
    decision = "prompt",
    justification = "Evitar pushes accidentales.",
)

prefix_rule(
    pattern = ["rm", "-rf"],
    decision = "forbidden",
    justification = "Bloquear borrado destructivo.",
)

prefix_rule(
    pattern = ["sudo"],
    decision = "forbidden",
    justification = "Bloquear privilegios elevados.",
)